# Adapted from geerlingguy/top500-benchmark at {{ hpl_top500_upstream_revision }}.
# The upstream MIT license is installed with the benchmark provenance.
SHELL        = /bin/sh
CD           = cd
CP           = cp
LN_S         = ln -s
MKDIR        = mkdir
RM           = /bin/rm -f
TOUCH        = touch

ARCH         = top500
TOPdir       = {{ hpl_install_root }}/tmp/hpl-{{ hpl_version }}
INCdir       = $(TOPdir)/include
BINdir       = $(TOPdir)/bin/$(ARCH)
LIBdir       = $(TOPdir)/lib/$(ARCH)
HPLlib       = $(LIBdir)/libhpl.a

MPdir        = {{ hpl_install_root }}/mpich
MPinc        = -I $(MPdir)/include
MPlib        = -L $(MPdir)/lib -lmpich

LAdir        = {{ hpl_install_root }}/openblas
LAinc        = -I $(LAdir)/include
LAlib        = $(LAdir)/lib/libopenblas.a -lpthread

F2CDEFS      = -DAdd_ -DF77_INTEGER=int -DStringSunStyle
HPL_INCLUDES = -I$(INCdir) -I$(INCdir)/$(ARCH) $(LAinc) $(MPinc)
HPL_LIBS     = $(HPLlib) $(LAlib) $(MPlib)
HPL_OPTS     = {{ hpl_compile_flags }}
HPL_DEFS     = $(F2CDEFS) $(HPL_OPTS) $(HPL_INCLUDES)

CC           = {{ hpl_install_root }}/mpich/bin/mpicc
CCNOOPT      = $(HPL_DEFS)
CCFLAGS      = $(HPL_DEFS)
LINKER       = {{ hpl_install_root }}/mpich/bin/mpif77
LINKFLAGS    = $(HPL_OPTS)
ARCHIVER     = ar
ARFLAGS      = r
RANLIB       = echo
